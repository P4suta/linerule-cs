root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{json,toml,yaml,yml}]
indent_size = 2

[*.{csproj,props,targets,slnx}]
indent_size = 2

[*.cs]
indent_size = 4

# === Style: pattern matching, var, file-scoped namespace, etc. ===
csharp_style_namespace_declarations = file_scoped:error
csharp_style_prefer_top_level_statements = false:silent
csharp_prefer_braces = true:warning
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = true:silent
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_prefer_switch_expression = true:warning
csharp_style_prefer_pattern_matching = true:warning
csharp_style_prefer_not_pattern = true:warning

dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_collection_expression = when_types_loosely_match:suggestion
dotnet_style_prefer_simplified_boolean_expressions = true:warning
dotnet_style_readonly_field = true:warning

# === Severity overrides — exhaustiveness + closed-DU enforcement ===
# IDE0010: add missing cases to switch (closed-DU exhaustiveness)
dotnet_diagnostic.IDE0010.severity = error
# IDE0072: missing cases in switch expression
dotnet_diagnostic.IDE0072.severity = error
# IDE0046: convert to conditional expression — keep as suggestion
dotnet_diagnostic.IDE0046.severity = suggestion

# === Severity overrides — async hygiene ===
dotnet_diagnostic.CA2007.severity = error  # ConfigureAwait
dotnet_diagnostic.CA2016.severity = error  # forward CancellationToken
dotnet_diagnostic.VSTHRD001.severity = error
dotnet_diagnostic.VSTHRD200.severity = warning

# === Severity overrides — defensive ===
dotnet_diagnostic.CA1063.severity = error  # IDisposable correctly
dotnet_diagnostic.CA1822.severity = warning  # static where possible
dotnet_diagnostic.CA1851.severity = error  # multiple enumerations
dotnet_diagnostic.CA2208.severity = error  # ArgumentException correctly
dotnet_diagnostic.CA1801.severity = error  # unused parameters

# === Architecturally justified relaxations (rule is legitimately stale for our design) ===
# Every relaxation below is documented in an ADR. Code-level fixes are preferred;
# only rules that directly contradict the design intent end up here
# (memory: feedback_honest_analyzer_fix).

# CA1034: "Do not nest type". The C# 13 closed-DU idiom (abstract record root +
# `private protected` ctor + nested sealed records) is the *only* way to express
# a closed sum type in C# until union types ship. The rule predates this idiom.
# See docs/adr/0002-state-model.md.
dotnet_diagnostic.CA1034.severity = none

# S3060 (Sonar): "Offload code conditional on type test to subclass and remove
# the condition." Contradicts the closed-DU `Match` / `switch`-expression
# pattern, where the centralized type test is the *whole point* of an ADT.
# Distributing the logic via virtual methods is exactly what FP languages spent
# decades trying to escape from. See docs/adr/0002-state-model.md.
dotnet_diagnostic.S3060.severity = none

# === Disable noisy rules in test projects only (configured via per-folder .editorconfig later if needed) ===

# === Naming ===
dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case_style
dotnet_naming_symbols.types.applicable_kinds = class,struct,interface,enum
dotnet_naming_symbols.types.applicable_accessibilities = *
dotnet_naming_style.pascal_case_style.capitalization = pascal_case

dotnet_naming_rule.private_field_underscore.severity = warning
dotnet_naming_rule.private_field_underscore.symbols = private_fields
dotnet_naming_rule.private_field_underscore.style = underscore_camel_case
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

[tests/**/*.cs]
# tests may use [Fact] / [Property] without docs
dotnet_diagnostic.CS1591.severity = none
# tests instantiate plenty of records inline; relax CA1822 noise
dotnet_diagnostic.CA1822.severity = silent
# xUnit convention: test names are snake_case for readability. CA1707
# was written for production APIs, not test specs.
dotnet_diagnostic.CA1707.severity = none
# Test code legitimately runs on the test runner's sync context; ConfigureAwait
# is a library-author concern, not a test-method concern.
dotnet_diagnostic.CA2007.severity = none
# Test methods named after behavior may incidentally include "Fire" / "Raise" —
# CA1030 suggests such methods should be events; not applicable to test methods.
dotnet_diagnostic.CA1030.severity = none

[**/Linerule.XTask/**/*.cs]
# XTask may write to Console (it's a CLI lint runner, not a library)
dotnet_diagnostic.CA1303.severity = none

[src/Linerule.Cli/**.cs]
# CLI entry point legitimately uses Console output via Spectre
dotnet_diagnostic.CA1303.severity = none
# CLI / app code is the SyncContext owner — ConfigureAwait is a library-author
# concern. Relax for the executable assemblies (CA2007 / MA0004).
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.MA0004.severity = none

[src/Linerule.Platform.Windows/**.cs]
# Same rationale as Linerule.Cli — the Win32 / WinAppSDK app is the
# SyncContext owner via DispatcherQueueController.
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.MA0004.severity = none
# Sonar S1450 fires on fields kept solely as GC roots for unmanaged
# callbacks (a P/Invoke necessity). The rule has no way to express
# "this field anchors a delegate the OS holds". Justified per-file relax.
dotnet_diagnostic.S1450.severity = none
# CA2216 vs MA0055 conflict: modern .NET (Meziantou) discourages finalizers
# in favor of SafeHandle / process-exit cleanup. For our process-bound OS
# hooks (RegisterHotKey, SetWinEventHook), MA0055 wins.
dotnet_diagnostic.CA2216.severity = none
# Console.WriteLine on a CLI app does not need the async variant.
dotnet_diagnostic.S6966.severity = none
dotnet_diagnostic.CA1849.severity = none
# Top-level run loop legitimately catches `Exception` to surface
# initialization failures to the user (otherwise WinAppSDK Bootstrap /
# Compositor errors are silent).
dotnet_diagnostic.CA1031.severity = none
