# Tooling-only npm package.json (hosts commitlint for the commit-msg hook
# via `just hooks` → `docker compose run --rm dev npm install`). The
# install lands at /workspace/node_modules through the bind mount, so the
# directory and its derived lockfile surface in host `git status` —
# ignore both.
node_modules/
package-lock.json

